# ============================================================
# Amazon Review Analyzer — Environment Variables
# Copy this file to .env and fill in your actual keys.
# NEVER commit .env to version control.
# ============================================================

# ScrapingBee — product listing scraper
# Get yours at: https://www.scrapingbee.com/
SCRAPINGBEE_API_KEY=your_scrapingbee_api_key_here

# Apify — Amazon Reviews Scraper actor
# Get yours at: https://apify.com/
APIFY_API_TOKEN=your_apify_api_token_here

# Groq — LLM inference (llama-3.3-70b-versatile)
# Get yours at: https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here

# ChromaDB — local vector store persistence path
CHROMA_PERSIST_DIR=./chroma_db
